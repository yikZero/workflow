{
  "name": "@workflow/example-sveltekit",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "generate:workflows": "node ../scripts/generate-workflows-registry.js ./src/workflows ./src/lib/_workflows.ts",
    "predev": "pnpm generate:workflows",
    "prebuild": "pnpm generate:workflows",
    "dev": "vite dev",
    "build": "vite build",
    "start": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "devDependencies": {
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.0",
    "@types/lodash.chunk": "^4.2.9",
    "@workflow/world-postgres": "workspace:*",
    "svelte": "^5.54.0",
    "svelte-check": "^4.3.2",
    "typescript": "^5.9.2",
    "vite": "^7.3.2",
    "vite-plugin-devtools-json": "^1.0.0"
  },
  "dependencies": {
    "@ai-sdk/react": "2.0.76",
    "@node-rs/xxhash": "1.7.6",
    "@opentelemetry/api": "^1.9.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@swc/core": "catalog:",
    "@vercel/otel": "^1.13.0",
    "@workflow/ai": "workspace:*",
    "ai": "catalog:",
    "exsolve": "^1.0.7",
    "lodash.chunk": "^4.2.0",
    "workflow": "workspace:*",
    "zod": "catalog:"
  }
}
