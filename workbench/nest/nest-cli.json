{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "builder": "swc",
    "typeCheck": false,
    "assets": [
      {
        "include": "../.nestjs/workflow/*.mjs",
        "outDir": "dist"
      },
      {
        "include": "../.nestjs/workflow/manifest.json",
        "outDir": "dist"
      }
    ]
  },
  "watchOptions": {
    "preserveWatchOutput": true
  }
}
