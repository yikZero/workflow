{
  "$schema": "https://unpkg.com/@changesets/config@3.1.1/schema.json",
  "changelog": [
    "@changesets/changelog-github",
    { "repo": "vercel/workflow" }
  ],
  "commit": false,
  "fixed": [["workflow", "@workflow/core"]],
