{
  "name": "@workflow/vitest",
  "version": "4.0.1-beta.8",
  "description": "Vitest plugin for testing Workflow DevKit workflows",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/vercel/workflow.git",
    "directory": "packages/vitest"
  },
  "scripts": {
    "build": "tsc",
    "clean": "tsc --build --clean && rm -rf dist ||:",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@workflow/builders": "workspace:*",
    "@workflow/core": "workspace:*",
    "@workflow/rollup": "workspace:*",
    "@workflow/world": "workspace:*",
    "@workflow/world-local": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@workflow/tsconfig": "workspace:*",
    "vite": "7.1.12"
  },
  "peerDependencies": {
    "vite": ">=6.0.0",
    "vitest": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  }
}
